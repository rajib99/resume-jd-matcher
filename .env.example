# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key — get one free at https://console.groq.com/
GROQ_API_KEY=gsk_...

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Model to use for matching (llama-3.3-70b-versatile is free and high quality)
# Other options: llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=INFO

# Runtime environment label (informational only)
ENVIRONMENT=production
