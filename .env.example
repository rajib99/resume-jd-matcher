# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key — get one free at https://aistudio.google.com/
GEMINI_API_KEY=AIza...

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Gemini model to use for matching (gemini-2.0-flash has a generous free tier)
GEMINI_MODEL=gemini-2.0-flash

# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=INFO

# Runtime environment label (informational only)
ENVIRONMENT=production
